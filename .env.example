# ═══════════════════════════════════════════════════════════
#  AIKO DESKTOP — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your details.
# Only the LLM section is required. Everything else is optional.

# ── LLM Provider (Required) ──────────────────────────────
# Default: Ollama (local). Install from https://ollama.com
# Supported: Ollama, OpenRouter, Gemini, OpenAI, Anthropic, DeepSeek
PROVIDER=Ollama
MODEL_NAME=gemma3:4b
LLM_URL=http://127.0.0.1:11434/api/chat
LLM_BASE_URL=http://127.0.0.1:11434/v1

# ── API Keys (Optional — only if using cloud providers) ──
API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Bot Tokens (Optional — for Discord/Telegram) ────────
DISCORD_TOKEN=
TELEGRAM_TOKEN=
MASTER_ID=

# ── Image Generation (Optional) ─────────────────────────
IMAGE_GEN_KEY=
IMAGE_GEN_MODEL=

# ── Admin (Optional — comma-separated user IDs) ─────────
ADMIN_IDS=
